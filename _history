e su propio eje para buscar.\" line16=\"            buscarOponente();\" line17=\"        }\" line18=\"    });\" numlines=\"19\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"function atacar() {\" line1=\"        // Motor Izquierdo: Adelante\" line2=\"        pins.digitalWritePin(DigitalPin.P13, 1);\" line3=\"        pins.digitalWritePin(DigitalPin.P14, 0);\" line4=\"\" line5=\"        // Motor Derecho: Adelante\" line6=\"        pins.digitalWritePin(DigitalPin.P15, 1);\" line7=\"        pins.digitalWritePin(DigitalPin.P16, 0);\" line8=\"\" line9=\"        // Mostrar un ícono de enojo en la matriz LED\" line10=\"        basic.showIcon(IconNames.Angry);\" line11=\"    }\" numlines=\"12\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"function buscarOponente() {\" line1=\"        // Motor Izquierdo: Adelante\" line2=\"        pins.digitalWritePin(DigitalPin.P13, 1);\" line3=\"        pins.digitalWritePin(DigitalPin.P14, 0);\" line4=\"\" line5=\"        // Motor Derecho: Atrás (esto hace que el robot gire en su lugar)\" line6=\"        pins.digitalWritePin(DigitalPin.P15, 0);\" line7=\"        pins.digitalWritePin(DigitalPin.P16, 1);\" line8=\"\" line9=\"        // Mostrar un ícono de búsqueda en la matriz LED\" line10=\"        basic.showIcon(IconNames.Diamond);\" line11=\"    }\" numlines=\"12\"></mutation></block></next></block></next></block></statement></block></xml>"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":378,"length1":44,"diffs":[[1,""]]}]},{"type":"added","filename":"test.ts","value":"// tests go here; this will not be compiled when this package is used as an extension.\n"}]}],"snapshots":[{"timestamp":1778186194860,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"http://www.w3.org/1999/xhtml\">\n  <block type=\"pxt-on-start\"></block>\n  <block type=\"device_forever\"></block>\n</xml>","main.ts":"\n